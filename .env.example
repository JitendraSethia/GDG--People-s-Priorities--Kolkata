# Copy this file to .env and fill in values as you obtain them.
# The app runs fully in rule-based fallback mode with everything below left blank.

# --- Gemini (Google AI Studio path - recommended for the hackathon) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Gemini (Vertex AI path - only if you already have a GCP project) ---
USE_VERTEX_AI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-south1

# --- Google Maps JavaScript API ---
MAPS_API_KEY=

# --- App config ---
SECRET_KEY=dev-insecure-key
POLL_INTERVAL_MS=5000

# --- Officials login (shared passcode for the demo) ---
OFFICIAL_PASSCODE=kolkata2026
